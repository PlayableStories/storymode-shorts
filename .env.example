# Copy this file to `.env.local` (gitignored) for local development.
#
# The submission form (/submit) posts to Web3Forms. Get a free access key at
# https://web3forms.com (enter the inbox you want submissions to land in, then
# click the verification email). The key is public and can be domain-locked in
# the Web3Forms dashboard, so it's safe to expose in a static build.
#
# In production this same value is set as the GitHub repo *variable*
# WEB3FORMS_ACCESS_KEY (Settings → Secrets and variables → Actions → Variables),
# which the deploy workflow passes in at build time.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
